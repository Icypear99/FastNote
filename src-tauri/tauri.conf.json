{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "个人空间工作台",
  "version": "0.1.0",
  "identifier": "com.workspace.personal",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "个人空间工作台",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 680,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
